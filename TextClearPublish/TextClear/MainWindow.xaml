<Window
    x:Class="TextClear.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="TextClear">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" 
              Grid.Row="0" 
              Background="Transparent" 
              HorizontalAlignment="Stretch" 
              VerticalAlignment="Stretch">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                <Image Source="icon.ico" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="TextClear" Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12" Opacity="0.8"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <NavigationView x:Name="RootNav" PaneDisplayMode="Left" IsBackButtonVisible="Collapsed" IsSettingsVisible="True" Header="文本净化空间">
                <NavigationView.MenuItems>
                    <NavigationViewItem Icon="Document" Content="主编辑器" Tag="Editor" />
                </NavigationView.MenuItems>

                <Grid Padding="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="2">
                        <TextBox x:Name="InputTextArea" PlaceholderText="在此粘贴带格式的内容..." AcceptsReturn="True" TextWrapping="Wrap" BorderThickness="0" FontSize="16" Padding="16" Background="Transparent"/>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="0,20,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" Spacing="20">
                                <ToggleSwitch x:Name="TrimSpacesToggle" Header="自动去首尾空格" IsOn="True" FontSize="12"/>
                                <ToggleSwitch x:Name="RemoveEmptyLinesToggle" Header="合并多余空行" IsOn="False" FontSize="12"/>
                            </StackPanel>

                            <Button Grid.Column="1" x:Name="CleanButton" Click="CleanButton_Click" Style="{StaticResource AccentButtonStyle}" Padding="32,12" CornerRadius="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE7AD;" FontSize="16" />
                                    <TextBlock Text="全量净化并复制" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <InfoBar x:Name="ResultInfoBar" Title="净化完成" Message="已成功复制到剪贴板" IsOpen="False" Severity="Success" Margin="0,12,0,0" />
                    </StackPanel>
                </Grid>
            </NavigationView>
        </Grid>
    </Grid>
</Window>